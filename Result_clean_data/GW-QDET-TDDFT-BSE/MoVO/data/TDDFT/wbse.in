input_west:
    west_prefix: west

wbse_init_control:
  wbse_init_calculation: S
  solver: TDDFT
  localization: W
  overlap_thr: 0.000001

wbse_control:
  wbse_calculation: D
  n_liouville_maxiter: 1000
  n_liouville_eigen: 10
  trev_liouville: 0.0001
  trev_liouville_rel: 0.001
  l_preconditioning: True
  n_exx_lowrank: 4000
