### compare casscf with results from GAMESS before nevpt2 ###

! SARC/J AutoAux tightscf moread  DKH
 %MaxCore 20000
 %moinp "casscf_4-7.gbw"
 %pal nprocs 128 end
 %casscf
  nel 4
  norb 7
  mult 3,1
  nroots = 6,3
  actorbs CanonOrbs
  weights[0] = 1,1,1,1,1,1 #automatically choose equal weight for all
  weights[1] = 1,1,1
  rel
     dosoc true
     doSSC true
     printlevel 4
  end
end

