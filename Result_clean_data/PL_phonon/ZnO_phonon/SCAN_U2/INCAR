system = zno

Starting parameters:
  PREC = A       # accurate calculation
  ISTART = 0     # job : 0-new 1-cont 2-samecut
  ICHARG = 2     # charge: 1-file 2-atom 10-constant
  ISPIN = 1      # spin
  KPAR = 8

Electronic scf:
  ALGO = Normal
  ENCUT = 520
  NELM = 200   #max electronic steps
  EDIFF = 1e-08
  LREAL = False	# default: false, the real space one is recommended for more than 20 atoms 
  LMIXTAU = True # send kinetic part to density mixer: try true  when scf not  converge
  NELMDL = -5 #number of non-self-consistent steps at the beginning.
  NELMIN = 5 #minimum number of electronic self-consistency steps.

Ionic relaxation:
  EDIFFG = -0.01 #top criterion for ELM
  IBRION = 6    #calculation type: 6 for phonon with finite difference
  ISYM = 2     # 0-nonsym 1-usesym 2-fastsym, default: 2 for PAW dataset

DOS related values
  ISMEAR = 0
  SIGMA = 0.02

SCAN functional
  LASPH = True    # non-spherical contributions to charge; needed for U, exx or metaGGA
  METAGGA = Scan
  LMAXMIX = 4      #(Mixing cut-off, 4-d, 6-f) required by DFT+U

Write flags:
  LCHARG = False   # write CHGCAR
  LWAVE = False	   #write WAVECAR
  LORBIT = 11      #not read RWIGS line, gives DOSCAR and lm decomposed PROCAR




phonon dispersion:
  LPHON_DISPERSION = .true.

DFT+U Calculation 
LDAU   = .TRUE.        (Activate DFT+U) 
LDATYPE=  2            (Dudarev, only U-J matters) 
LDAUL  =  2  1         (l Orbitals for each species,-1 for not adding U) 
LDAUU  =  2  0         (U for each species: here for Zn and O) 
LDAUJ  =  0  0         (J for each species) 
LDAUPRINT=1            (Verbosity, 0 low, 1 high) 
LMAXMIX=  4            (Mixing cut-off, 4-d, 6-f)
